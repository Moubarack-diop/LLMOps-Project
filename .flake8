[flake8]
max-line-length = 88
exclude =
    .git,
    __pycache__,
    notebooks/,
    .venv,
    venv,
    *.egg-info,
    dist,
    build
ignore = E203, W503
# E501 toléré dans les tests : les fixtures contiennent des notes cliniques
# d'exemple sur une seule ligne.
per-file-ignores =
    tests/*:S101,E501
